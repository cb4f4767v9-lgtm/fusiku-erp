    "@fontsource/noto-sans-arabic": "^5.2.5",
    "@vitejs/plugin-react": "^4.0.0",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "i18next": "^25.8.19",
    "jsbarcode": "^3.12.3",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
