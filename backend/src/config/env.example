# Fusiku - Environment Configuration
# Copy to .env and configure for your environment

# Environment: development | staging | production
NODE_ENV=development
APP_ENV=development

# Server
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fusiku_erp

# Redis (optional - for jobs and caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Upload
UPLOAD_PATH=uploads
UPLOAD_MAX_SIZE=10485760

# CORS
CORS_ORIGIN=true

# Storage (local | s3 | spaces - future)
STORAGE_PROVIDER=local

# Electron hot UI update (optional — leave FRONTEND_HOT_ZIP_URL empty to skip)
FRONTEND_HOT_VERSION=1.0.0
# Example: http://127.0.0.1:3001/static-updates/frontend.zip
FRONTEND_HOT_ZIP_URL=
FRONTEND_HOT_SHA256=

# Cloud sync target (optional)
CLOUD_API_BASE_URL=
CLOUD_API_KEY=
