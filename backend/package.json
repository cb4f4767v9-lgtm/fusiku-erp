{
  "name": "fusiku-erp-backend",
  "version": "1.0.2",
  "description": "FUSIKU ERP API Gateway",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint \"src/core/**/*.ts\" \"src/http/**/*.ts\" \"src/infrastructure/**/*.ts\" \"src/modules/**/*.ts\" \"src/ai/actionableOutput.ts\" \"src/routes/auth.routes.ts\" \"src/routes/invoice.routes.ts\" \"src/routes/inventory.routes.ts\" \"src/routes/expense.routes.ts\" \"src/routes/ai.routes.ts\" \"src/controllers/invoice.controller.ts\" \"src/controllers/inventory.controller.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --runInBand --forceExit",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/worker-entry.ts",
    "prisma:generate": "prisma generate",
    "build:full": "prisma generate && tsc",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "db:deploy": "prisma db push",
    "backup:db": "node scripts/backup-db.js",
    "db:studio": "prisma studio",
    "seed:demo": "tsx prisma/seed-demo.ts",
    "seed:master": "tsx prisma/seed-master-data.ts",
    "reset-admin": "tsx scripts/reset-admin.ts",
    "create-admin": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.41",
    "@langchain/openai": "^1.4.4",
    "@opentelemetry/api": "1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.49.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.49.0",
    "@opentelemetry/semantic-conventions": "^1.30.1",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.47.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.13.4",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.76.1",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.3.4",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.0",
    "pino": "^9.5.0",
    "pino-http": "^10.2.0",
    "prisma": "^5.22.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.6.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
