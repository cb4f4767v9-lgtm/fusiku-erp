// FUSIKU ERP - Prisma Schema
// Think Smart. Play Cool.
// Phase 5 SaaS Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Company {
  id           String   @id @default(cuid())
  name         String
  logo         String?
  email        String?
  phone        String?
  address      String?
  isActive     Boolean  @default(true)
  /// SaaS onboarding: mobile_shop | repair_shop | trading
  businessType String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches        Branch[]
  users           User[]
  suppliers       Supplier[]
  customers       Customer[]
  purchases       Purchase[]
  sales           Sale[]
  repairs         Repair[]
  stockAlerts     StockAlert[]
  companySettings CompanySettings?
  subscriptions   Subscription[]
  apiKeys         ApiKey[]
  webhooks        Webhook[]
  warranties      Warranty[]

  inventory            Inventory[]
  barcodeSequences     BarcodeSequence[]
  stockMovements       StockMovement[]
  transfers            Transfer[]
  refurbishJobs        RefurbishJob[]
  fileUploads          FileUpload[]
  aiAlerts             AIAlert[]
  integrationLogs      IntegrationLog[]
  deviceHistories      DeviceHistory[]
  inventoryParts       InventoryPart[]
  expenses             Expense[]
  payments             Payment[]
  profitReports        ProfitReport[]
  currencies           Currency[]
  currencyHistories    CurrencyHistory[]
  supplierFxRates      SupplierFxRate[]
  investors            Investor[]
  investorTransactions InvestorTransaction[]
  profitDistributions  ProfitDistribution[]
  usage                CompanyUsage?
  imeiHistories        IMEIHistory[]
  imeiRecords          IMEIRecord[]

  // Sales Orders + Invoicing
  salesOrders SalesOrder[]
  invoices    Invoice[]

  translations Translation[]
  exchangeRateHistories ExchangeRateHistory[]

  setupProfile SetupProfile?
}

/// Post-signup onboarding wizard answers (per-tenant).
model SetupProfile {
  id               String   @id @default(cuid())
  companyId         String   @unique
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  businessType      String
  platform          String
  /// Array of ISO codes + optional sentinel 'OTHER'.
  sourcingCountries Json
  sourcingOther     String?
  requirements      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Master Data - Core foundation for ERP
model MasterCategory {
  id     String  @id @default(cuid())
  name   String
  nameZh String?
  nameAr String?
  nameUr String?

  translations MasterCategoryTranslation[]

  @@unique([name])
}

model MasterCategoryTranslation {
  id             String         @id @default(cuid())
  categoryId     String
  category       MasterCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  /// BCP-47 base language tag e.g. en | zh | ar | ur
  language       String
  translatedName String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([categoryId, language])
  @@index([language])
}

model MasterSparePart {
  id   String @id @default(cuid())
  name String @unique
}

model MasterScreenQuality {
  id   String @id @default(cuid())
  name String @unique
}

model MasterToolBrand {
  id   String @id @default(cuid())
  name String @unique
}

model StorageSize {
  id     String @id @default(cuid())
  sizeGb Int    @unique // 16, 32, 64, 128, 256, 512, 1024
  label  String @unique // "16GB", "64GB", "1TB"
}

model DeviceColor {
  id   String @id @default(cuid())
  name String @unique
}

model DeviceQuality {
  id   String @id @default(cuid())
  name String @unique
}

model DeviceFault {
  id   String @id @default(cuid())
  name String @unique
}

model CompanySettings {
  id                    String    @id @default(cuid())
  companyId             String    @unique
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Company operating / reporting currency (does not change ledger USD pivot).
  baseCurrency          String    @default("USD")
  /// Legacy alias kept for backward compatibility with older clients.
  currency              String    @default("USD")
  timezone              String    @default("UTC")
  taxRate               Float     @default(0)
  invoicePrefix         String    @default("INV")
  logo                  String?
  /// Desk spread in basis points (1 bp = 0.01%). Buy/sell derived from mid; 0 = legacy single-rate display.
  spreadBps             Int       @default(0)
  /// Optional book equity in USD for capital reporting (company-owned capital).
  companyEquityUsd      Float?
  /// Inventory pricing method used for NEW sales only (historical sales are never recalculated).
  pricingMethod         String    @default("FIFO") // FIFO | LIFO | CURRENT
  /// Optional flag for "profit locked" milestone tracking (does not mutate historical sales).
  pricingLocked         Boolean   @default(false)
  pricingLockedAt       DateTime?
  /// When plan allows `removeBranding`, tenant may hide the footer credit (Enterprise).
  hidePoweredByBranding Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model SubscriptionPlan {
  id                    String   @id @default(cuid())
  name                  String   @unique
  /// Base recurring price (USD/month) before per-branch / per-module add-ons.
  priceMonthly          Float    @default(0)
  maxUsers              Int      @default(10)
  maxBranches           Int      @default(3)
  /// Feature toggles, e.g. { "multiCurrency": true, "aiInsights": false, "removeBranding": false }
  features              Json     @default("{}")
  active                Boolean  @default(true)
  /// flat | per_branch | per_module | unlimited
  pricingModel          String   @default("flat")
  /// Used when pricingModel = per_branch (USD per extra branch / month).
  pricePerBranchMonthly Float?
  /// Used when pricingModel = per_module: { "aiInsights": 29, "forexTrading": 19 }
  modulePrices          Json?
  /// When true, maxUsers / maxBranches caps are not enforced.
  limitsUnlimited       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions Subscription[]
}

/// One active billing row per company (maps to SaaS "CompanySubscription").
model Subscription {
  id                   String           @id @default(cuid())
  companyId            String
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId               String
  plan                 SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate            DateTime
  endDate              DateTime
  status               String           @default("active") // active | expired | cancelled | trial
  trialEndsAt          DateTime?
  /// Stripe Customer id (billing Phase 4.1 — no SDK wired yet).
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([companyId])
}

/// Cached usage counters per tenant (recomputed from source tables).
model CompanyUsage {
  companyId         String   @id
  company           Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activeUsers       Int      @default(0)
  activeBranches    Int      @default(0)
  inventoryCount    Int      @default(0)
  salesCountMonthly Int      @default(0)
  updatedAt         DateTime @updatedAt
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// SystemAdmin role has no companyId - can access global admin

enum UserBranchRole {
  SUPER_ADMIN
  BRANCH_ADMIN
  BRANCH_USER
}

model User {
  id         String         @id @default(cuid())
  email      String
  password   String
  name       String
  phone      String?
  roleId     String
  role       Role           @relation(fields: [roleId], references: [id])
  /// Branch isolation role for operational access control (Phase 1).
  /// SUPER_ADMIN may have branchId = null; branch roles must have branchId.
  branchRole UserBranchRole @default(BRANCH_USER)
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId   String?
  branch     Branch?        @relation(fields: [branchId], references: [id])
  /// UI / API locale: en | zh | ar | ur (BCP-47 base).
  language   String         @default("en")
  /// Preferred display / settlement currency (ISO 4217) for this user in the app shell.
  currency   String         @default("USD")
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]
  repairs           Repair[]
  refurbishJobs     RefurbishJob[]
  transfers         Transfer[]
  passwordResets    PasswordReset[]
  branchPermissions BranchPermission[]

  // Sales Orders + Invoicing
  createdSalesOrders SalesOrder[] @relation("SalesOrderCreatedBy")
  createdInvoices    Invoice[]    @relation("InvoiceCreatedBy")

  @@unique([companyId, email])
  @@index([companyId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String?
  adminName String?
  /// Default operating currency for this branch (ISO 4217). Exposed as `defaultCurrency` in auth/session payloads.
  currency  String?  @default("USD")
  /// Enterprise: branch-level operating margin/overhead percent (0–100). Used in profit analytics.
  marginPercent Float @default(0)
  /// Default UI language for users assigned to this branch when they have no explicit `User.language`.
  defaultLanguage String @default("en")
  country   String?
  province  String?
  city      String?
  address   String?
  phone     String?
  logo      String? // public URL path e.g. /uploads/branding/uuid.png
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  inventory          Inventory[]
  purchases          Purchase[]
  sales              Sale[]
  transfersFrom      Transfer[]          @relation("TransferFrom")
  transfersTo        Transfer[]          @relation("TransferTo")
  stockMovements     StockMovement[]
  inventoryLocations InventoryLocation[]
  inventoryParts     InventoryPart[]
  branchPermissions  BranchPermission[]
  contacts           BranchContact[]
  expenses           Expense[]
  repairs            Repair[]
  refurbishJobs      RefurbishJob[]
  aiAlerts           AIAlert[]

  // Sales Orders + Invoicing
  salesOrders SalesOrder[]
  invoices    Invoice[]
  payments    Payment[]

  @@index([companyId])
}

model BranchContact {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  contactType String // phone
  value       String
  createdAt   DateTime @default(now())

  @@index([branchId])
}

model Supplier {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Default settlement / quote currency for this supplier (ISO 4217).
  currency         String   @default("USD")
  name             String
  companyName      String?
  email            String?
  website          String?
  country          String // required
  province         String?
  city             String?
  address          String?
  openingBalance   Float    @default(0)
  balanceType      String   @default("debit")
  paymentMethod    String?
  moneyStatus      String?
  availableBalance Float    @default(0)
  blockedBalance   Float    @default(0)
  // total_balance = availableBalance + blockedBalance (computed)
  // Legacy
  contact          String?
  phone            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchases       Purchase[]
  fxRates         SupplierFxRate[]
  supplierRatings SupplierRating[]
  priceHistory    PriceHistory[]
  contacts        SupplierContact[]

  @@index([companyId])
}

model SupplierContact {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  contactType String // phone | whatsapp | wechat | email | alipay
  value       String
  qrCodeUrl   String?
  createdAt   DateTime @default(now())

  @@index([supplierId])
}

model Customer {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  companyName    String?
  email          String?
  website        String?
  country        String?
  province       String?
  city           String?
  address        String?
  openingBalance Float    @default(0)
  balanceType    String   @default("debit")
  paymentMethod  String?
  moneyStatus    String?
  phone          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales     Sale[]
  repairs   Repair[]
  purchases Purchase[]
  contacts  CustomerContact[]

  // Sales Orders + Invoicing
  salesOrders SalesOrder[]
  invoices    Invoice[]
  payments    Payment[]

  @@index([companyId])
}

model CustomerContact {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactType String // phone | whatsapp | wechat | email
  value       String
  qrCodeUrl   String?
  createdAt   DateTime @default(now())

  @@index([customerId])
}

model PhoneBrand {
  id           String                  @id @default(cuid())
  name         String                  @unique
  createdAt    DateTime                @default(now())
  phoneModels  PhoneModel[]
  translations PhoneBrandTranslation[]
}

model PhoneBrandTranslation {
  id             String     @id @default(cuid())
  brandId        String
  brand          PhoneBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  /// BCP-47 base language tag e.g. en | zh | ar | ur
  language       String
  translatedName String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([brandId, language])
  @@index([language])
}

model PhoneModel {
  id           String                  @id @default(cuid())
  brandId      String
  brand        PhoneBrand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name         String
  releaseYear  Int?
  createdAt    DateTime                @default(now())
  variants     PhoneVariant[]
  translations PhoneModelTranslation[]

  @@unique([brandId, name])
  @@index([brandId])
}

model PhoneModelTranslation {
  id             String     @id @default(cuid())
  modelId        String
  model          PhoneModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  /// BCP-47 base language tag e.g. en | zh | ar | ur
  language       String
  translatedName String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([modelId, language])
  @@index([language])
}

model PhoneVariant {
  id          String                @id @default(cuid())
  modelId     String
  model       PhoneModel            @relation(fields: [modelId], references: [id], onDelete: Cascade)
  storage     String
  color       String
  createdAt   DateTime              @default(now())
  inventory   Inventory[]
  deviceSpecs DeviceSpecification[]

  @@unique([modelId, storage, color])
}

model DeviceGrade {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  inventory     Inventory[]
  refurbishJobs RefurbishJob[]
}

model Inventory {
  id                     String        @id @default(cuid())
  companyId              String
  company                Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  imei                   String        @unique
  barcode                String?       @unique
  /// phone | part | accessory
  productType            String        @default("phone")
  brand                  String
  model                  String
  storage                String
  color                  String
  condition              String
  purchasePrice          Float
  /// True when cost basis is not fully auditable (e.g. pre-migration stock). Reports must show the legacy-cost warning label.
  /// Optional one-time SQL after deploy: UPDATE "Inventory" SET "isLegacyCost" = true WHERE "costUsd" IS NULL;
  isLegacyCost           Boolean       @default(false)
  /// Optional: unit cost in `originalCurrency` before FX to USD (audit trail: original → converted → costUsd).
  originalCost           Float?
  originalCurrency       String?
  /// Ledger cost in USD at acquisition (authoritative for COGS / FIFO-LIFO). Null = legacy row (use purchasePrice as USD heuristic in reads).
  costUsd                Float?
  /// ISO currency of `purchasePrice` at acquisition (when set with costUsd).
  purchaseCurrency       String?
  /// Units of `purchaseCurrency` per 1 USD at acquisition (same convention as Sale.exchangeRateAtTransaction).
  exchangeRateAtPurchase Float?
  cargoCost              Float         @default(0)
  sellingPrice           Float
  branchId               String
  branch                 Branch        @relation(fields: [branchId], references: [id])
  /// available | sold | repair | damaged | transferred
  status                 String        @default("available")
  notes                  String?
  phoneVariantId         String?
  phoneVariant           PhoneVariant? @relation(fields: [phoneVariantId], references: [id])
  deviceGradeId          String?
  deviceGrade            DeviceGrade?  @relation(fields: [deviceGradeId], references: [id])
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  imeiRecords    IMEIRecord[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]
  transferItems  TransferItem[]
  deviceHistory  DeviceHistory[]

  // Sales Orders + Invoicing
  salesOrderItems SalesOrderItem[]
  invoiceItems    InvoiceItem[]

  @@index([imei])
  @@index([barcode])
  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
}

model BarcodeSequence {
  id         String   @id @default(cuid())
  companyId  String   @unique
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model IMEIRecord {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  imei        String
  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id])
  action      String
  notes       String?
  createdAt   DateTime   @default(now())

  @@index([imei])
  @@index([companyId])
}

model StockMovement {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryId  String
  inventory    Inventory @relation(fields: [inventoryId], references: [id])
  movementType String // purchase | sale | repair | refurbish | transfer | adjustment
  branchId     String
  branch       Branch    @relation(fields: [branchId], references: [id])
  userId       String?
  referenceId  String?
  quantity     Int       @default(1)
  createdAt    DateTime  @default(now())

  @@index([inventoryId])
  @@index([companyId])
  @@index([branchId])
  @@index([createdAt])
}

model Transfer {
  id                    String    @id @default(cuid())
  companyId             String
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromBranchId          String
  fromBranch            Branch    @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId            String
  toBranch              Branch    @relation("TransferTo", fields: [toBranchId], references: [id])
  createdById           String
  createdBy             User      @relation(fields: [createdById], references: [id])
  status                String    @default("pending") // pending | approved | completed | cancelled
  approvedById          String?
  approvedAt            DateTime?
  transferMarginPercent Float     @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  transferItems TransferItem[]

  @@index([companyId])
}

model TransferItem {
  id          String    @id @default(cuid())
  transferId  String
  transfer    Transfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
}

/// TODO(phase-decimal): migrate monetary `Float` fields (e.g. totalAmount, cargoCost, totalAmountUsd, cargoCostUsd) to Prisma `Decimal`; keep arithmetic in `src/utils/money.ts`.
model Purchase {
  id                        String    @id @default(cuid())
  companyId                 String
  company                   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId                String?
  supplier                  Supplier? @relation(fields: [supplierId], references: [id])
  customerId                String?
  customer                  Customer? @relation(fields: [customerId], references: [id])
  branchId                  String
  branch                    Branch    @relation(fields: [branchId], references: [id])
  totalAmount               Float
  cargoCost                 Float     @default(0)
  taxAmount                 Float     @default(0)
  otherCosts                Float     @default(0)
  currency                  String    @default("USD")
  /// Trading-grade audit aliases (safe additions). Same meaning as `currency` / `exchangeRateAtTransaction`.
  purchaseCurrency          String?
  /// Normalized totals in USD (ledger); optional for legacy rows — COALESCE with raw amounts when currency was USD
  totalAmountUsd            Float?
  cargoCostUsd              Float?
  /// Units of `currency` per 1 USD at posting time; 1 for USD
  exchangeRateAtTransaction Float?
  /// Alias of `exchangeRateAtTransaction` for purchases (auditable intent).
  exchangeRateAtPurchase    Float?
  status                    String    @default("pending")
  notes                     String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  purchaseItems    PurchaseItem[]
  inventoryBatches InventoryBatch[]

  @@index([companyId])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  imei        String
  /// phone | part | accessory
  productType String   @default("phone")
  brand       String
  model       String
  storage     String
  color       String
  condition   String
  price       Float
  quantity    Int      @default(1)
}

/// TODO(phase-decimal): migrate monetary `Float` fields (e.g. totalAmount, profit, totalAmountUsd, profitUsd) to Prisma `Decimal`; keep arithmetic in `src/utils/money.ts`.
/// DEPRECATED — use Invoice as the operational billing source of truth.
/// Kept temporarily for legacy compatibility and historical migration bridges.
model Sale {
  id                        String    @id @default(cuid())
  companyId                 String
  company                   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId                  String
  branch                    Branch    @relation(fields: [branchId], references: [id])
  customerId                String?
  customer                  Customer? @relation(fields: [customerId], references: [id])
  totalAmount               Float
  profit                    Float     @default(0)
  /// ISO currency of totalAmount / profit (defaults USD for legacy)
  currency                  String    @default("USD")
  /// Ledger-normalized amounts in USD; optional on legacy rows
  totalAmountUsd            Float?
  profitUsd                 Float?
  /// Units of `currency` per 1 USD at posting time; 1 for USD
  exchangeRateAtTransaction Float?
  /// Pricing method snapshot used when this sale was created (audit safety).
  pricingMethodUsed         String?
  paymentMethod             String    @default("cash")
  status                    String    @default("completed")
  notes                     String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  saleItems  SaleItem[]
  warranties Warranty[]

  // Sales Orders + Invoicing (migration bridge)
  invoices Invoice[] @relation("InvoiceSale")

  @@index([companyId])
}

/// DEPRECATED — use InvoiceItem for billing/profit reporting.
/// Kept temporarily for legacy compatibility and migration fallback.
model SaleItem {
  id                String    @id @default(cuid())
  saleId            String
  sale              Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventoryId       String
  inventory         Inventory @relation(fields: [inventoryId], references: [id])
  imei              String
  sellingPrice      Float
  /// Cost basis in sale transaction currency (legacy / display); COGS audit uses costUsdUsed.
  purchasePrice     Float
  profit            Float
  /// Locked ledger COGS in USD for this line (audit).
  costUsdUsed       Float?
  /// Locked revenue in USD for this line (after sale-level discount allocation).
  revenueUsd        Float?
  /// Locked profit in USD for this line.
  profitUsd         Float?
  /// Snapshot of company pricing method when the sale was posted.
  pricingMethodUsed String?
}

// =============================================================================
// Sales Orders + Invoicing (Phase 12)
// =============================================================================

model SalesOrder {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId   String
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  orderNumber String?
  status      String  @default("draft") // draft | confirmed | cancelled | invoiced
  notes       String?

  currency            String @default("USD")
  /// Units of `currency` per 1 USD at order time (snapshot); 1 for USD
  exchangeRateAtOrder Float?

  subtotal        Float  @default(0)
  discountPercent Float  @default(0)
  totalAmount     Float  @default(0)
  totalAmountUsd  Float?

  createdById String?
  createdBy   User?     @relation("SalesOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  confirmedAt DateTime?
  invoicedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    SalesOrderItem[]
  invoices Invoice[]

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
}

model SalesOrderItem {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  imei        String?

  description String?
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  lineTotal   Float   @default(0)

  createdAt DateTime @default(now())

  @@index([salesOrderId])
  @@index([inventoryId])
  @@index([imei])
}

model Invoice {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId   String
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  salesOrderId String?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  /// Optional link to legacy POS `Sale` for compatibility during migration.
  saleId       String?
  sale         Sale?       @relation("InvoiceSale", fields: [saleId], references: [id], onDelete: SetNull)

  invoiceNumber String?
  status        String  @default("unpaid") // unpaid | partial | paid | void
  notes         String?

  currency                  String @default("USD")
  /// Units of `currency` per 1 USD at posting time; 1 for USD
  exchangeRateAtTransaction Float?

  subtotal        Float  @default(0)
  discountPercent Float  @default(0)
  totalAmount     Float  @default(0)
  totalAmountUsd  Float?

  amountPaid    Float  @default(0)
  amountPaidUsd Float?

  profit    Float  @default(0)
  profitUsd Float?

  createdById String?
  createdBy   User?   @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  imei        String?

  description String?
  quantity    Int     @default(1)

  /// Transaction currency values
  costPrice Float @default(0)
  salePrice Float @default(0)
  profit    Float @default(0)

  /// Locked USD audit values
  costUsdUsed       Float?
  revenueUsd        Float?
  profitUsd         Float?
  /// Optional refurbishing cost (USD) included in COGS for this line.
  refurbCostUsdUsed Float?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([inventoryId])
  @@index([imei])
}

model Repair {
