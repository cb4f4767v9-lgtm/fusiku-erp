// =============================================================================
// ERP EXTENSION — Database Architecture (Phase 11)
// Extends schema for phone refurbishing business with IMEI tracking.
// =============================================================================

// --- 1. IMEI Intelligence System ---

model DeviceHistory {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryId String?
  inventory   Inventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  imei        String
  action      String // purchase | repair | refurbish | sale | transfer | grade_change
  fromStatus  String?
  toStatus    String?
  fromGrade   String?
  toGrade     String?
  purchaseId  String?
  repairId    String?
  saleId      String?
  transferId  String?
  userId      String?
  notes       String?
  metadata    String?
  createdAt   DateTime   @default(now())

  @@index([imei])
  @@index([companyId])
  @@index([inventoryId])
  @@index([createdAt])
}

// --- 2. Smart Inventory System ---

model InventoryLocation {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  name      String // e.g. "Shelf A1", "Warehouse Zone B"
  code      String?
  type      String   @default("shelf") // shelf | zone | bin | counter
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parts InventoryPart[]

  @@unique([branchId, code])
  @@index([branchId])
}

model InventoryBatch {
  id          String    @id @default(cuid())
  purchaseId  String?
  purchase    Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  batchNumber String    @unique
  receivedAt  DateTime  @default(now())
  expiryDate  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  parts InventoryPart[]

  @@index([purchaseId])
}

model InventoryPart {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  category    String // part | accessory | tool
  quantity    Int                @default(0)
  minQuantity Int                @default(0)
  unit        String             @default("pcs")
  unitCost    Float              @default(0)
  locationId  String?
  location    InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  batchId     String?
  batch       InventoryBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  repairParts RepairPart[]
  movements   InventoryPartMovement[]

  @@unique([branchId, sku])
  @@index([companyId])
  @@index([branchId])
  @@index([category])
}

model InventoryPartMovement {
  id            String        @id @default(cuid())
  partId        String
  part          InventoryPart @relation(fields: [partId], references: [id], onDelete: Cascade)
  movementType  String // in | out | adjust | transfer
  quantity      Int
  referenceType String? // repair | refurbish | purchase
  referenceId   String?
  branchId      String
  userId        String?
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([partId])
  @@index([createdAt])
}

// --- 3. Repair Management System ---

model RepairPart {
  id        String         @id @default(cuid())
  repairId  String
  repair    Repair         @relation(fields: [repairId], references: [id], onDelete: Cascade)
  partId    String?
  part      InventoryPart? @relation(fields: [partId], references: [id], onDelete: SetNull)
  partName  String // denormalized for history
  quantity  Int            @default(1)
  unitCost  Float          @default(0)
  totalCost Float          @default(0)
  notes     String?
  createdAt DateTime       @default(now())

  @@index([repairId])
}

// --- 4. Refurbishing Pipeline ---

model RefurbishmentTest {
  id             String       @id @default(cuid())
  refurbishJobId String
  refurbishJob   RefurbishJob @relation(fields: [refurbishJobId], references: [id], onDelete: Cascade)
  testType       String // display | battery | camera | connectivity | cosmetic
  status         String       @default("pending") // pending | pass | fail
  notes          String?
  testedAt       DateTime?
  testedById     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  results RefurbishmentResult[]

  @@index([refurbishJobId])
}

model RefurbishmentResult {
  id        String            @id @default(cuid())
  testId    String
  test      RefurbishmentTest @relation(fields: [testId], references: [id], onDelete: Cascade)
  field     String // grade_before | grade_after | cosmetic_work | defect_found
  value     String
  createdAt DateTime          @default(now())

  @@index([testId])
}

// --- 5. Supplier & Purchasing System ---

model SupplierRating {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  rating       Int // 1-5
  deliveryTime Int? // days
  qualityScore Float?
  notes        String?
  orderId      String?
  createdAt    DateTime @default(now())

  @@index([supplierId])
}

model PriceHistory {
  id         String    @id @default(cuid())
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  brand      String
  model      String
  storage    String?
  condition  String?
  price      Float
  recordedAt DateTime  @default(now())

  @@index([supplierId])
  @@index([brand, model])
}

// --- 6. Multi-Branch System ---

model BranchPermission {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  canView     Boolean  @default(true)
  canEdit     Boolean  @default(false)
  canTransfer Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
}

// --- 7. Financial Intelligence System ---

/// TODO(phase-decimal): migrate monetary `Float` fields (amount, amountUsd) to Prisma `Decimal`; keep arithmetic in `src/utils/money.ts`.
model Expense {
  id                        String   @id @default(cuid())
  companyId                 String
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId                  String?
  branch                    Branch?  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  category                  String // rent | salary | cargo | misc | (legacy: utilities | parts | labor | shipping | other)
  amount                    Float
  currency                  String   @default("USD")
  /// Amount normalized to USD (ledger); optional on legacy rows
  amountUsd                 Float?
  /// Units of `currency` per 1 USD at posting time; 1 for USD
  exchangeRateAtTransaction Float?
  description               String?
  referenceType             String? // repair | refurbish | transfer
  referenceId               String?
  expenseDate               DateTime @default(now())
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([companyId])
  @@index([expenseDate])
  @@index([branchId])
}

/// External capital providers (equity investors vs debt lenders).
/// TODO(phase-decimal): migrate monetary `Float` fields (capitalAmount, related transactions) to Prisma `Decimal`; keep arithmetic in `src/utils/money.ts`.
model Investor {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  /// investor = profit-sharing eligible; lender = principal / interest only (no sharePercentage)
  type            String   @default("investor")
  /// Declared / book principal in `currency` (complement cash flows in InvestorTransaction)
  capitalAmount   Float    @default(0)
  currency        String   @default("USD")
  /// 0–100 when type is investor; null for lenders
  sharePercentage Float?
  startDate       DateTime @default(now())
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions        InvestorTransaction[]
  profitDistributions ProfitDistribution[]

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, active])
}

model InvestorTransaction {
  id                        String   @id @default(cuid())
  companyId                 String
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investorId                String
  investor                  Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  type                      String // deposit | withdrawal
  amount                    Float
  currency                  String   @default("USD")
  amountUsd                 Float?
  exchangeRateAtTransaction Float?
  date                      DateTime @default(now())
  createdAt                 DateTime @default(now())

  @@index([companyId])
  @@index([investorId])
  @@index([date])
}

/// Paid profit share allocations per investor (auditable history).
model ProfitDistribution {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  investorId String
  investor   Investor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  /// Amount paid/allocated in USD (ledger currency for distributions)
  amountUsd  Float
  /// Period label for reporting/audit, e.g. "2026-03" or "2026-Q1"
  period     String
  /// Date the distribution was paid/recorded
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([investorId])
  @@index([period])
  @@index([date])
}

model Payment {
  id                        String    @id @default(cuid())
  companyId                 String
  company                   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId                  String?
  branch                    Branch?   @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customerId                String?
  customer                  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  saleId                    String?
  purchaseId                String?
  invoiceId                 String?
  invoice                   Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amount                    Float
  currency                  String    @default("USD")
  amountUsd                 Float?
  /// Units of `currency` per 1 USD at posting time; 1 for USD
  exchangeRateAtTransaction Float?
  method                    String    @default("cash") // cash | card | transfer | mobile
  reference                 String?
  status                    String    @default("completed")
  paidAt                    DateTime  @default(now())
  createdAt                 DateTime  @default(now())

  @@index([companyId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([invoiceId])
}

model ProfitReport {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId     String?
  periodType   String // daily | weekly | monthly
  periodStart  DateTime
  periodEnd    DateTime
  totalRevenue Float    @default(0)
  totalCost    Float    @default(0)
  repairCost   Float    @default(0)
  partsCost    Float    @default(0)
  profit       Float    @default(0)
  deviceCount  Int      @default(0)
  createdAt    DateTime @default(now())

  @@unique([companyId, branchId, periodType, periodStart])
  @@index([companyId])
  @@index([periodStart])
}
