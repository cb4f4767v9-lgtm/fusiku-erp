/// @deprecated Global FX windows — use per-tenant `Currency` / `currencyService` for reads. Kept for legacy writes only.
model ExchangeRate {
  id            String    @id @default(cuid())
  currency      String
  rate          Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
}

model Currency {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code      String

  /// Display symbol (e.g. $, د.إ). Optional; clients may fall back to code.
  symbol         String?
  /// Optional presentation hint: `symbol_first` | `code_suffix` | `narrow`.
  displayFormat  String?

  /// forex | crypto | commodity | supplier
  type           String @default("forex")
  /// Provider identifier e.g. exchangerate.host | binance | manual
  sourceProvider String @default("manual")

  /// Live rate vs USD pivot (1 USD = baseRate * code)
  baseRate Float @default(0)

  /// Previous `finalRate` snapshot for change% calculations
  previousRate Float?

  /// Optional market price (manual or imported) - quote per 1 USD (same basis as rates)
  marketPrice Float?

  marginPercent Float @default(0)
  finalRate     Float @default(0)

  /// true = auto (finalRate computed), false = manual (finalRate = manualRate)
  isAuto     Boolean @default(true)
  manualRate Float?

  /// When live feed last updated baseRate for this currency
  lastUpdatedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  histories CurrencyHistory[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([code])
}

/// Supplier-specific FX override rates (manual entry).
/// Rates are stored in the same convention as Currency: units of `currencyCode` per 1 USD.
model SupplierFxRate {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  currencyCode String
  rate         Float
  effectiveAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([supplierId, currencyCode])
  @@index([companyId])
  @@index([supplierId])
  @@index([companyId, currencyCode])
  @@index([effectiveAt])
}

/// Currency rate history (auditable): stores snapshots of finalRate per 1 USD.
model CurrencyHistory {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currencyCode String
  currency     Currency @relation(fields: [companyId, currencyCode], references: [companyId, code], onDelete: Cascade)
  rate         Float
  date         DateTime @default(now())

  @@index([companyId])
  @@index([companyId, currencyCode])
  @@index([date])
}

/// Cross-currency exchange history snapshot (enterprise analytics).
/// Convention: `rate` means `1 fromCurrency = rate toCurrency` at `date` (derived from USD-pivot finalRate).
model ExchangeRateHistory {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromCurrency String
  toCurrency   String
  rate         Float
  date         DateTime @default(now())
  source       String   @default("derived") // derived | manual | external
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, fromCurrency, toCurrency])
}

/// UI translation overrides + backend-localized strings (Phase g11n).
/// - `key`: stable translation key, aligned with i18next keys when used for UI.
/// - `languageCode`: BCP-47 base language code (en | zh | ar | ur).
/// - Fallback preference: verified > auto-generated > English.
model Translation {
  id              String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  key             String
  languageCode    String
  value           String
  isAutoGenerated Boolean  @default(false)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, key, languageCode])
  @@index([companyId])
  @@index([companyId, languageCode])
  @@index([companyId, key])
}

