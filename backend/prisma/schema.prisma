  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  repairCost       Float
  status           String    @default("pending") // received | diagnosing | waiting_parts | repairing | testing | completed
  notes            String?
  photoUrl         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  repairParts RepairPart[]

  @@index([companyId])
  @@index([branchId])
}

model RefurbishJob {
  id             String       @id @default(cuid())
  companyId      String
  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Branch isolation (Phase 2): nullable for legacy rows; branch users must only access their own branch.
  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  incomingDevice String
  partsUsed      String?
  laborCost      Float
  finalCondition String
