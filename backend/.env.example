# Production: tune pool size on the URL (Prisma pool). Example:
# DATABASE_URL="postgresql://user:pass@host:5432/db?connection_limit=10&pool_timeout=20"
DATABASE_URL="postgresql://postgres:password@localhost:5432/fusiku?connection_limit=10"

# HTTP server (frontend dev expects http://localhost:3001 by default)
PORT=3001
# Optional: DB connect retries at startup (exponential backoff from DB_CONNECT_RETRY_MS)
# DB_CONNECT_MAX_RETRIES=5
# DB_CONNECT_RETRY_MS=1000
# Production: use random secrets at least 32 characters each (never commit real secrets).
JWT_SECRET="dev-access-token-secret-min-32-chars-please-change"
REFRESH_SECRET="dev-refresh-token-secret-min-32-chars-please-change"
# Access token TTL (default 15m). Use JWT_EXPIRES to override, e.g. "15m", "1h".
JWT_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
FRONTEND_URL="http://localhost:3001"

# Production REQUIRED: comma-separated browser Origin allowlist (e.g. https://app.example.com).
# When NODE_ENV=production, missing CORS_ORIGIN aborts startup; missing/weak JWT_SECRET aborts startup.
# CORS_ORIGIN="http://localhost:5173,https://app.example.com"

# Behind nginx/load balancer: set so express-rate-limit and IP logging see client IP.
# TRUST_PROXY=true

# General API rate limit (requests per RATE_LIMIT_WINDOW_MS). Default 200 per 15 minutes — active in index.ts.
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=200

# Scheduled DB backup (pg_dump). Set DATABASE_BACKUP_ENABLED=false if client tools are not installed.
# BACKUP_DIR defaults to ./backups (under process.cwd(), usually backend/). BACKUP_RETENTION_DAYS default 14.
# DATABASE_BACKUP_ENABLED="true"
# BACKUP_DIR=""
# BACKUP_RETENTION_DAYS="14"
# PG_DUMP_PATH="pg_dump"

# Currency: offline-first. External fetch is opt-in only (requires outbound internet).
# USE_EXTERNAL_RATES="false"

# First-run default admin (empty database). In production, set BOOTSTRAP_ADMIN_PASSWORD to a strong password (16+ chars, letters and digits); weak defaults are blocked.
# BOOTSTRAP_DEFAULT_ADMIN="true"
# BOOTSTRAP_ADMIN_EMAIL="admin@fusiku.com"
# BOOTSTRAP_ADMIN_PASSWORD=""

# SaaS: public POST /auth/register is disabled by default. Enable only for controlled environments.
# ALLOW_PUBLIC_REGISTER="false"
# Optional server-to-server bypass (min 16 chars); send header X-Internal-Register-Token: <value>
# INTERNAL_REGISTER_TOKEN=""

# When true, all mutating /api/v1/* tenant routes require a Subscription row (legacy DBs with no row get 402).
# Default unset/false: no subscription row is allowed (backward compatible).
# SAAS_REQUIRE_SUBSCRIPTION_FOR_WRITES="false"

# Public SaaS signup (POST /api/v1/signup). Off by default — set true to allow new tenants + auto-login JWT.
# ENABLE_PUBLIC_SIGNUP="false"
# Optional: tighten signup rate limit (defaults 8 requests / IP / hour).
# SIGNUP_RATE_LIMIT_MAX="8"
# SIGNUP_RATE_LIMIT_WINDOW_MS="3600000"

# Observability (optional)
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
# SENTRY_TRACES_SAMPLE_RATE="0.1"
# EXPOSE_HTTP_METRICS="1"
